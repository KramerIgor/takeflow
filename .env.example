# Copy to .env locally and fill in real values.
# Never commit a real API key.
SEGMIND_API_KEY=

# Segmind API base URL.
SEGMIND_API_BASE=https://api.segmind.com

# Optional project output paths.
# On Windows, prefer a local output root such as C:\AI_OUTPUT.
# On macOS, omit these values to use ~/Movies/Takeflow or set a path such as ~/Movies/Takeflow.
# OUTPUT_DIR may point at one active project; OUTPUT_ROOT may point at the parent folder.
OUTPUT_DIR=C:\Takeflow\outputs\MyFirstProject
OUTPUT_ROOT=C:\Takeflow\outputs

# Optional local server settings used by the packaged launcher.
TAKEFLOW_HOST=127.0.0.1
TAKEFLOW_PORT=7860

# Optional update manifest URL. Default points at the public Takeflow update.json.
# Override for forks or private test channels.
TAKEFLOW_UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/KramerIgor/takeflow/main/update.json
