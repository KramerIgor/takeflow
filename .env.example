# Segmind API key.
# Real key must be stored only in local .env, never in code or chat.
SEGMIND_API_KEY=

# Segmind model used by default.
SEGMIND_MODEL=seedance-2.0

# Segmind API base URL.
SEGMIND_API_BASE=https://api.segmind.com

# Active project output folder.
#
# Important:
# - /mnt/c/AI_OUTPUT is the common Windows output root.
# - Psailor_kun is the current active project folder.
# - Later Stage 7 will add project selection/creation in GUI.
#
# Windows structure:
#   C:\AI_OUTPUT\
#     Psailor_kun\
#       results\
#         _inbox\
#           take_000001\
OUTPUT_DIR=/mnt/c/AI_OUTPUT/Psailor_kun

# Optional common output root for all projects.
# If empty, the parent folder of OUTPUT_DIR is used.
# Example Windows path from WSL:
# OUTPUT_ROOT=/mnt/c/AI_OUTPUT
OUTPUT_ROOT=

# Stage 7 flat project structure:
# Final MP4 files: <Project>/videos/Episode_XX_Scene_YYY_take_ZZZZZZ.mp4
# Technical run data: <Project>/runs/Episode_XX_Scene_YYY_take_ZZZZZZ/
